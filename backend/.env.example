GEMINI_API_KEY=your-key-from-https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash

# Default: Postgres via docker compose up -d in ./docker
DATABASE_URL=postgresql+psycopg://loguser:logpass@localhost:5432/loganalyzer
# Quick local alternative (no Docker needed):
# DATABASE_URL=sqlite:///./log_analyzer.db

MAX_LOG_CHARS=200000
CORS_ORIGINS=http://localhost:5173
